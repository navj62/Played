{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend by navya",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon -r dotenv/config --experimental-json-modules src/index.js",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently -n \"server,client\" -c \"yellow,cyan\" \"npm run dev\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix client",
    "install:client": "npm install --prefix client"
  },
  "keywords": [
    "javascript",
    "backend"
  ],
  "author": "Navya Jain",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.7.0",
    "cookie-parse": "^0.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.1",
    "mongoose-aggregate-paginate-v2": "^1.1.4",
    "multer": "^2.0.1"
  }
}
